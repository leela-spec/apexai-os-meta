# LLM Wiki — .gitignore

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Temporary files
*.tmp
*.bak

# The wiki content itself (each project builds its own)
wiki/

# Source files: ignore user content, but ship demo files for quickstart
.raw/*
!.raw/greek-olympians.md
!.raw/perseus-medusa.md

# Claude Code
.claude/

# LLM Wiki — CLAUDE.md is generated by setup-project.sh
CLAUDE.md
