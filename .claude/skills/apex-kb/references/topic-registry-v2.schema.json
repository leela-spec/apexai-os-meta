{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "apex.kb.topic-registry.v2",
  "type": "object",
  "required": ["topics"],
  "properties": {
    "schema": {
      "enum": ["apex.kb.topic-registry.v2", "2"]
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "slug", "status", "target_page"],
        "properties": {
          "name": {"type": "string"},
          "slug": {"type": "string"},
          "status": {"enum": ["not_started", "draft", "complete"]},
          "target_page": {"type": "string"},
          "keywords": {
            "type": "array",
            "items": {"type": "string"}
          },
          "phrases": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Multi-word strong-signal phrases. A phrase match in filename/H1/heading is never suppressed by a negative term."
          },
          "aliases": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Alternate names for the same topic; scored identically to phrases."
          },
          "supporting_terms": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Weaker single-term signals. Back-compat: when phrases/aliases are absent, legacy keywords are read as supporting_terms."
          },
          "negative_terms": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Terms that suppress a body-only/supporting-term match for this topic. Never suppresses a filename, H1, heading, phrase, or alias hit."
          },
          "ambiguous_terms": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Terms that are common/generic in this corpus; matches on these alone do not establish a body-strong tier without co-occurrence."
          },
          "target_queries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["query_id", "question", "priority", "answer_requirements", "expected_page"],
              "properties": {
                "query_id": {"type": "string"},
                "question": {"type": "string"},
                "priority": {"enum": ["critical", "routine", "supporting"]},
                "answer_requirements": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "expected_page": {"type": "string"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
