{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apex.local/schemas/deterministic-markdown-patcher2/patch-policy.schema.json",
  "title": "patch_policy",
  "type": "object",
  "required": [
    "schema_version",
    "path_allowlist",
    "report_directory",
    "allowed_operations",
    "full_file_rewrite"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "patch_policy.v1"
    },
    "path_allowlist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "protected_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      },
      "default": []
    },
    "report_directory": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "allowed_operations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_command"
      },
      "default": []
    },
    "full_file_rewrite": {
      "type": "boolean",
      "default": false
    }
  },
  "$defs": {
    "validation_command": {
      "type": "object",
      "required": [
        "name",
        "command",
        "timeout_seconds"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
