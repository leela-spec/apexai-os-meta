+def dedup_graph_edges(edges: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
+    seen: set = set()
+    result = []
+    for edge in sorted(edges, key=_graph_edge_key):
+        key = _graph_edge_key(edge)
+        if key in seen:
+            continue
+        seen.add(key)
+        result.append(edge)
+    return result
 
 
