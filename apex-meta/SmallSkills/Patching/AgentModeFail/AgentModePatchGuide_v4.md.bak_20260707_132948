okf_document:
  id: apex_agent_mode_git_native_patch_pack_process_v2
  title: "Apex Agent Mode Git-Native Patch-Pack Process"
  status: "binding_process_standard"
  purpose: >
    Define the repeatable process for using ChatGPT Agent Mode to create
    a validated multi-file patch pack without direct implementation mutation,
    over-engineered fallback modes, or pseudo-patches.

context:
  problem:
    summary: >
      A working Agent Mode patch-pack process became non-repeatable because later
      prompts drifted away from the original Git-native artifact contract.
    not_the_problem:
      - "Agent Mode is categorically unable to build patch packs."
      - "The repo task is impossible."
      - "More historical failure context makes the run safer."
      - "More fallback branches improve reliability."
    actual_problem:
      - "Prompt contamination from stale failed runs."
      - "Environment-mode ambiguity."
      - "Allowing API/connector reconstruction after repo preflight failure."
      - "Allowing manually assembled patch-like files."
      - "Allowing marker/stub checks to replace behavior and git-apply validation."

core_principle:
  one_line: >
    Agent Mode may create patch-pack artifacts only when operating from a real
    live terminal Git worktree; patches must be generated by git diff and validated
    by git apply --check before the run can pass.

role_split:
  agent_mode_builder:
    role: "bounded autonomous patch-pack builder"
    owns:
      - "read source plan"
      - "read live target files"
      - "modify one target file at a time"
      - "generate one Git-native patch per target file"
      - "validate every patch with git apply --check"
      - "validate cumulative patch application"
      - "revert target files"
      - "commit/export patch-pack artifacts only"
    must_not_own:
      - "final implementation commit"
      - "manual equivalent application"
      - "patching target files as final repo state"
      - "repo reconstruction from API snippets"
      - "broad redesign"

  codex_or_terminal_applier:
    role: "deterministic patch applier/verifier"
    owns:
      - "apply existing patch pack"
      - "run git apply --check"
      - "run tests and behavior checks"
      - "verify changed-file scope"
      - "commit and push implementation changes"
    must_not_own:
      - "invent missing patch content"
      - "repair invalid patch syntax manually while claiming patch application passed"

success_contract:
  required_inputs:
    repo:
      owner_repo: "leela-spec/apexai-os-meta"
      branch: "main"
      source_of_truth: "live terminal Git worktree only"

    source_plan:
      rule: "one authoritative repo-local source plan"
      fallback_search: "narrow folder search only"
      forbidden:
        - "giant failed transcripts as source"
        - "multiple competing plans"
        - "memory reconstruction"

    target_scope:
      rule: "explicit allowed target files"
      patch_rule: "one patch per target file"
      forbidden:
        - "patching files outside allowed list"
        - "touching apex-kb2 unless explicitly requested"
        - "runtime wiki mass rewrites unless explicitly requested"

    semantic_contract:
      required_markers:
        rule: "small list of observable required strings or behavior surfaces"
      forbidden_markers:
        rule: "small list of explicit non-goals"
      behavior_tests:
        rule: "required when scripts are modified"

git_native_method:
  preflight:
  
    commands:
      - "git rev-parse --show-toplevel"
      - "git rev-parse --is-inside-work-tree"
      - "git remote get-url origin"
      - "git branch --show-current"
      - "git status --porcelain"
      - "git checkout main"
      - "git pull --ff-only origin main"

    hard_stop_if:
      - "not a Git worktree"
      - "target files are unavailable"
      - "source plan is unavailable"
      - "git is unavailable"

    do_not_do_if_preflight_fails:
      - "do not use GitHub API snippets as baseline"
      - "do not create a synthetic repo"
      - "do not hand-write patch drafts"
      - "do not create partial pseudo-patches"
      - "do not claim artifact success"

  per_file_patch_loop:
    for_each_target_file:
      sequence:
        - "git checkout -- <target-file>"
        - "verify target file clean"
        - "modify only <target-file>"
        - "git diff --no-ext-diff -- <target-file> > <patch-file>"
        - "test -s <patch-file>"
        - "grep '^diff --git ' <patch-file>"
        - "verify exactly one diff header"
        - "git checkout -- <target-file>"
        - "git apply --check <patch-file>"
        - "git apply <patch-file>"
        - "git diff --name-only"
        - "verify only intended target file changed"
        - "run relevant local sanity checks"
        - "git checkout -- <target-file>"
        - "verify target file clean"

    forbidden:
      - "hand-written unified diff hunks"
      - "abbreviated hunk headers"
      - "manual hunk header editing"
      - "zero-context pseudo-patches"
      - "broad formatting"
      - "line-ending normalization across whole files"
      - "multi-target patch files"

  cumulative_validation:
    sequence:
      - "start from clean main"
      - "git apply --check every patch in manifest order"
      - "git apply every patch in manifest order"
      - "git diff --name-only"
      - "verify changed files equal target file set"
      - "run py_compile if Python changed"
      - "run behavior smoke tests if scripts changed"
      - "check required markers"
      - "check forbidden markers"
      - "revert all target files"
      - "verify target files clean"

  artifact_output:
    required_files:
      - "000-patch-manifest.md"
      - "NNN-*.patch"
      - "999-codex-apply-handoff.md"
      - "validation-report.md"
    final_builder_state:
      target_files_modified: false
      patch_artifacts_present: true
      patch_artifacts_committed_or_exported: true

pass_fail_policy:
  pass:
    allowed_only_if:
      - "live Git worktree used"
      - "patches generated by git diff"
      - "all patches pass git apply --check"
      - "cumulative patch application passes"
      - "changed-file scope is exact"
      - "target files reverted"
      - "patch artifacts persisted"

  fail:
    required_if:
      - "no live Git worktree"
      - "source plan unreadable"
      - "target file missing"
      - "any patch has invalid syntax"
      - "any patch fails git apply --check"
      - "patch was hand-written or snippet-assembled"
      - "target files remain modified in builder final state"

  forbidden_verdicts:
    - "PASS_WITH_WORKAROUNDS"
    - "PASS despite git_apply_check_all FAIL"
    - "PASS when manual equivalent edits replaced patch validity"

minimal_failure_guards:
  guard_1_repo_truth:
    rule: "live terminal Git repo or hard fail"
    reason: "prevents API-baseline reconstruction and synthetic repo drift"

  guard_2_patch_authenticity:
    rule: "patches must come from git diff"
    reason: "prevents abbreviated hunk headers and pseudo-patches"

  guard_3_patch_validity:
    rule: "git apply --check is mandatory per patch and cumulative"
    reason: "prevents invalid artifacts from being treated as success"

  guard_4_artifact_boundary:
    rule: "Agent Mode final state contains patch artifacts only"
    reason: "prevents direct implementation mutation during builder run"

  guard_5_behavior_not_markers:
    rule: "script patches require compile and smoke behavior tests"
    reason: "prevents stub functions and marker-only success"

  guard_6_no_history_contamination:
    rule: "do not include giant failure histories inside execution prompt"
    reason: "prevents the agent from optimizing around stale failure narratives"

prompt_design_rules:
  write_the_prompt_as:
    - "mission"
    - "repo and branch"
    - "source plan"
    - "allowed target files"
    - "patch files"
    - "forbidden paths"
    - "required behavior"
    - "git-native procedure"
    - "validation"
    - "final report"

  do_not_include:
    - "long historical explanations"
    - "multiple environment modes"
    - "broad fallback frameworks"
    - "API reconstruction instructions"
    - "speculative blockers"
    - "old failure transcripts"
    - "architecture rediscovery"
    - "manual repair permissions"

  acceptable_context_size:
    rule: "short enough that the worker executes, not reasons about the process"
    target_shape: "one deterministic task prompt, not a research report"

canonical_agent_prompt_template:
  text: |
    # Agent Mode Task — <PATCH PACK NAME> Git-Native Patch-Pack Builder

    You are GPT-5.5 Agent Mode acting as the Git-native patch-pack builder.

    Mission:
    Create a validated Git-native patch pack.
    Do not apply the final implementation patches.
    Do not leave target files modified.
    Final state must contain patch-pack artifacts only.

    Repo:
    <owner/repo>
    Branch:
    main
    Patch-pack root:
    <patch-pack-root>

    Source of truth:
    Use the live terminal Git repository only.
    Do not reconstruct files from API snippets.
    Do not use previous failed outputs as source material.

    Preflight:
    Run:
      git rev-parse --show-toplevel
      git rev-parse --is-inside-work-tree
      git remote get-url origin
      git branch --show-current
      git status --porcelain
      git checkout main
      git pull --ff-only origin main

    If this is not a live Git worktree, stop:
      FINAL_REPORT:
        verdict: FAIL
        failed_step: repo_preflight
        patch_generation_started: false

    Read first:
      <primary source plan>

    Target files:
      001:
        target_file: <file>
        patch_file: <patch-pack-root>/001-<name>.patch

    Forbidden:
      - <forbidden path>
      - <forbidden behavior>

    Required changes:
      - <required behavior / marker>

    Procedure for each target:
      1. git checkout -- <target-file>
      2. verify target clean
      3. modify only that target file
      4. git diff --no-ext-diff -- <target-file> > <patch-file>
      5. test -s <patch-file>
      6. verify exactly one diff --git header
      7. git checkout -- <target-file>
      8. git apply --check <patch-file>
      9. temporarily apply patch and verify only target file changed
      10. run relevant sanity checks
      11. revert target file

    Cumulative validation:
      - git apply --check every patch in order
      - git apply every patch in order
      - verify changed files equal target files
      - run compile/tests if scripts changed
      - verify required markers
      - verify forbidden markers absent
      - revert target files

    Metadata:
      Create:
        <patch-pack-root>/000-patch-manifest.md
        <patch-pack-root>/999-codex-apply-handoff.md
        <patch-pack-root>/validation-report.md

    Persist:
      Commit and push patch-pack artifacts only.
      If push is unavailable, export archive and report PARTIAL_ARTIFACT_EXPORT.
      Do not claim pushed:true unless repository push succeeded.

    Final report:
      FINAL_REPORT:
        verdict: PASS|PARTIAL_ARTIFACT_EXPORT|FAIL
        patch_generation_started: true|false
        git_apply_check_all: PASS|FAIL
        target_files_modified: false
        patch_pack_artifacts_present: true
        pushed_patch_pack_to_main: true|false
        blockers: []

anti_drift_rule:
  binding_sentence: >
    The process is successful only if the patch artifacts are valid;
    manual equivalent implementation is a different task and must not be reported
    as patch-pack success.