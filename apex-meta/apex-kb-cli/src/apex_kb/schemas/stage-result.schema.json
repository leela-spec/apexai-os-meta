{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "run_id", "config_hash", "stage", "status", "started_at", "completed_at", "artifacts", "reason_code", "message", "metrics"],
  "properties": {
    "schema": {"const": "apex.kb.stage-result.v2"}, "run_id": {"type": "string"}, "config_hash": {"type": "string"},
    "stage": {"type": "string"}, "status": {"enum": ["completed", "blocked", "failed"]}, "started_at": {"type": "string"},
    "completed_at": {"type": "string"}, "artifacts": {"type": "array", "items": {"type": "string"}},
    "reason_code": {"type": ["string", "null"]}, "message": {"type": "string"}, "metrics": {"type": "object"}
  }
}
