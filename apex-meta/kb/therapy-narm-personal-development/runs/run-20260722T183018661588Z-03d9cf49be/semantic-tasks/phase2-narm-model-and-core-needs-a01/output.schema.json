            "additionalProperties": false,
            "properties": {
              "citations": {
                "items": {
                  "$ref": "#/$defs/citation"
                },
                "minItems": 1,
                "type": "array"
              },
              "claim": {
                "minLength": 1,
                "type": "string"
              },
              "state": {
                "enum": [
                  "present",
                  "proposed",
                  "historical",
                  "open",
                  "contradicted"
                ]
              }
            },
            "required": [
              "claim",
              "state",
              "citations"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "macro": {
          "minLength": 1,
          "type": "string"
        },
        "meso": {
          "minLength": 1,
          "type": "string"
        },
        "micro": {
          "minLength": 1,
          "type": "string"
        },
        "route": {
          "minLength": 1,
          "type": "string"
        },
        "target_answers": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "answer": {
                "minLength": 1,
                "type": "string"
              },
              "citations": {
                "items": {
                  "$ref": "#/$defs/citation"
                },
                "minItems": 1,
                "type": "array"
              },
              "query_id": {
                "minLength": 1,
                "type": "string"
              },
              "question": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "query_id",
              "question",
              "answer",
              "citations"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "title": {
          "minLength": 1,
          "type": "string"
        },
        "uncertainties": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "route",
        "title",
        "executive_summary",
        "macro",
        "meso",
        "micro",
        "target_answers",
        "key_claims",
        "evolution",
        "contradictions",
        "uncertainties"
      ],
      "type": "object"
