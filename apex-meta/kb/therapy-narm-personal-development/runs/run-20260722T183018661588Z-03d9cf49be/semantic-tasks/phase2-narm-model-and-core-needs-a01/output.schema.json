                  "string",
                  "null"
                ]
              },
              "freshness": {
                "type": "string"
              },
              "individual_value": {
                "type": "string"
              },
              "pointers": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "questions_supported": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "read_status": {
                "type": "string"
              },
              "repository_path": {
                "type": "string"
              },
              "source_id": {
                "type": "string"
              }
            },
            "required": [
              "source_id",
              "repository_path",
              "disposition",
              "read_status",
              "content_snapshot",
              "individual_value",
              "authority",
              "freshness",
              "duplicate_or_supersession",
              "pointers",
              "questions_supported"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "route": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "route",
        "title",
        "entries"
      ],
      "type": "object"
    },
    "citation": {
      "additionalProperties": false,
      "properties": {
        "pointer": {
          "minLength": 1,
          "type": "string"
        },
        "source_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "pointer"
      ],
      "type": "object"
    },
    "dossier": {
      "additionalProperties": false,
      "properties": {
        "contradictions": {
          "items": {
            "type": "string"
