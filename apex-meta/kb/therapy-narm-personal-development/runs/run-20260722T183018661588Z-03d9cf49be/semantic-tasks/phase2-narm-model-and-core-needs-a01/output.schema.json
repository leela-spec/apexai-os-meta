  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "atlas": {
      "$ref": "#/$defs/atlas"
    },
    "config_hash": {
      "type": "string"
    },
    "dossier": {
      "$ref": "#/$defs/dossier"
    },
    "phase": {
      "const": "phase2"
    },
    "run_id": {
      "type": "string"
    },
    "schema": {
      "const": "apex.kb.phase2-result.v2"
    },
    "task_id": {
      "type": "string"
    },
    "topic_id": {
      "type": "string"
    },
    "worker_context_id": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema",
    "run_id",
    "config_hash",
    "task_id",
    "phase",
    "topic_id",
    "worker_context_id",
    "dossier",
    "atlas"
  ],
  "type": "object"
}
