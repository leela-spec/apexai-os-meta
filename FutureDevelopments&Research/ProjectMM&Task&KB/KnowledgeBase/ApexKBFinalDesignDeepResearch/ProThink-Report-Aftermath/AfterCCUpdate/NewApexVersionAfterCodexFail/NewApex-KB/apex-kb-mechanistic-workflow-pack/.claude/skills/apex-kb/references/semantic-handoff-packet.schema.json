{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "apex.kb.semantic-handoff-packet.v2",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "config_hash",
    "stage",
    "task_mode",
    "topic_id",
    "instruction_file_path",
    "prompt_template_path",
    "batch_guide_path",
    "exact_input_files",
    "required_outputs",
    "allowed_writes",
    "forbidden_writes",
    "prior_validation_feedback",
    "completion_response",
    "short_trigger",
    "input_fingerprints"
  ],
  "properties": {
    "schema": {
      "const": "apex.kb.semantic-handoff-packet.v2"
    },
    "run_id": {
      "type": "string"
    },
    "config_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "stage": {
      "enum": [
        "phase1",
        "phase2",
        "semantic_acceptance"
      ]
    },
    "task_mode": {
      "enum": [
        "analyze_batch",
        "finalize_topic_analysis",
        "compile_topic",
        "repair_failed_checks",
        "evaluate_topic"
      ]
    },
    "topic_id": {
      "type": "string"
    },
    "instruction_file_path": {
      "type": "string"
    },
    "prompt_template_path": {
      "type": "string"
    },
    "batch_guide_path": {
      "type": "string"
    },
    "exact_input_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "required_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "purpose",
          "format_owner"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "format_owner": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "allowed_writes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "forbidden_writes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "prior_validation_feedback": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "message",
          "repair_scope",
          "affected_output"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "repair_scope": {
            "type": "string"
          },
          "affected_output": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "completion_response": {
      "type": "string"
    },
    "short_trigger": {
      "type": "string"
    },
    "input_fingerprints": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
