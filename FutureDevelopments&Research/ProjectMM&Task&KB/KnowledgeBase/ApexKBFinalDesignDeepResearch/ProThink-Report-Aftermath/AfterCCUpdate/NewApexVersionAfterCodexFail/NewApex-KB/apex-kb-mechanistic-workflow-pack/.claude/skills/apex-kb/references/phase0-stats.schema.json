{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "apex.kb.phase0-stats.v2",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "config_hash",
    "corpus",
    "topics",
    "extraction_warnings",
    "generated_at"
  ],
  "properties": {
    "schema": {
      "const": "apex.kb.phase0-stats.v2"
    },
    "run_id": {
      "type": "string"
    },
    "config_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "corpus": {
      "$ref": "#/$defs/corpus"
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/topic"
      }
    },
    "extraction_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "code",
          "message"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "generated_at": {
      "type": "string"
    }
  },
  "$defs": {
    "corpus": {
      "type": "object",
      "required": [
        "total_files",
        "included_files",
        "excluded_files",
        "unreadable_or_unsupported",
        "total_bytes",
        "file_count_by_extension",
        "heading_count_total",
        "heading_count_by_level",
        "exact_duplicate_groups",
        "possible_version_families"
      ],
      "additionalProperties": false,
      "properties": {
        "total_files": {
          "type": "integer",
          "minimum": 0
        },
        "included_files": {
          "type": "integer",
          "minimum": 0
        },
        "excluded_files": {
          "type": "integer",
          "minimum": 0
        },
        "unreadable_or_unsupported": {
          "type": "integer",
          "minimum": 0
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "file_count_by_extension": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "heading_count_total": {
          "type": "integer",
          "minimum": 0
        },
        "heading_count_by_level": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "exact_duplicate_groups": {
          "type": "integer",
          "minimum": 0
        },
        "possible_version_families": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "topic": {
      "type": "object",
      "required": [
        "topic_id",
        "candidate_count_total",
        "filename_or_title_matches",
        "h1_matches",
        "heading_matches",
        "body_strong_matches",
        "body_weak_matches",
        "linked_contextual_matches",
        "duplicate_paths_collapsed",
        "concentrated_work_pack_count",
        "held_in_custody_count",
        "zero_signal_custody_count",
        "locked_question_count",
        "questions_without_candidate_evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "topic_id": {
          "type": "string"
        },
        "candidate_count_total": {
          "type": "integer",
          "minimum": 0
        },
        "filename_or_title_matches": {
          "type": "integer",
          "minimum": 0
        },
        "h1_matches": {
          "type": "integer",
          "minimum": 0
        },
        "heading_matches": {
          "type": "integer",
          "minimum": 0
        },
        "body_strong_matches": {
          "type": "integer",
          "minimum": 0
        },
        "body_weak_matches": {
          "type": "integer",
          "minimum": 0
        },
        "linked_contextual_matches": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_paths_collapsed": {
          "type": "integer",
          "minimum": 0
        },
        "concentrated_work_pack_count": {
          "type": "integer",
          "minimum": 0
        },
        "held_in_custody_count": {
          "type": "integer",
          "minimum": 0
        },
        "zero_signal_custody_count": {
          "type": "integer",
          "minimum": 0
        },
        "locked_question_count": {
          "type": "integer",
          "minimum": 0
        },
        "questions_without_candidate_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
